{
  "manifest_version": 3,
  "name": "Marker HELP",
  "version": "1.0.0",
  "description": "ホバーで要素をハイライトし、クリックで番号付きマークを固定。色・線種を選び、サイドパネルでマーク一覧とCSSセレクタを確認・コピーできます。",
  "permissions": ["sidePanel", "tabs"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Marker HELP",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
