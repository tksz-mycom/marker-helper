{
  "manifest_version": 3,
  "name": "Marker:HELPER",
  "version": "1.0.0",
  "description": "DOM要素にマーカーを自由に設定できます。マーカーは、要素の上に重ねて表示され、要素を視覚的に識別するのに役立ちます。",
  "permissions": ["sidePanel", "tabs", "storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Marker:HELPER",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-marking": {
      "suggested_key": {
        "default": "Alt+Shift+M"
      },
      "description": "マーキングモードのオン/オフを切り替える"
    }
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
